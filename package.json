{
  "name": "auto-post-facebook-page",
  "version": "1.0.0",
  "description": "Lightweight worker that reads products from Supabase and posts them to a Facebook Page.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:pm2": "mkdir -p logs && pm2 start ecosystem.config.cjs",
    "pm2:start": "mkdir -p logs && pm2 start ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs auto-post-facebook-page",
    "pm2:restart": "pm2 restart auto-post-facebook-page",
    "pm2:stop": "pm2 stop auto-post-facebook-page",
    "pm2:delete": "pm2 delete auto-post-facebook-page",
    "start:once": "node src/run-once.js",
    "dev": "node --watch src/index.js",
    "check": "node --check src/index.js"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.5.0"
  }
}
